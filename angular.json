{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "pnpm",
    "schematicCollections": ["@schematics/angular", "playwright-ng-schematics"]
  },
  "newProjectRoot": "projects",
  "projects": {
    "public-app": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "changeDetection": "OnPush",
          "style": "scss"
        }
      },
      "root": "projects/public-app",
      "sourceRoot": "projects/public-app/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/public-app/src/main.ts",
            "tsConfig": "projects/public-app/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/public-app/public"
              }
            ],
            "styles": ["projects/public-app/src/styles.scss"],
            "stylePreprocessorOptions": {
              "includePaths": ["src"]
            },
            "server": "projects/public-app/src/main.server.ts",
            "outputMode": "server",
            "security": {
              "allowedHosts": [
                "analogjonestof.com",
                "www.analogjonestof.com",
                "public--analog-jones-v2.us-central1.hosted.app",
                "*.run.app",
                "localhost"
              ]
            },
            "ssr": {
              "entry": "projects/public-app/src/server.ts"
            }
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "projects/public-app/src/environments/environment.ts",
                  "with": "projects/public-app/src/environments/environment.prod.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "600kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "12kB",
                  "maximumError": "20kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "public-app:build:production"
            },
            "development": {
              "buildTarget": "public-app:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "setupFiles": ["projects/public-app/src/test-setup.ts"]
          }
        },
        "e2e": {
          "builder": "playwright-ng-schematics:playwright",
          "options": {
            "devServerTarget": "public-app:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "public-app:serve:production"
            }
          }
        }
      }
    },
    "admin-app": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "changeDetection": "OnPush",
          "style": "scss"
        }
      },
      "root": "projects/admin-app",
      "sourceRoot": "projects/admin-app/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/admin-app/src/main.ts",
            "tsConfig": "projects/admin-app/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/admin-app/public"
              }
            ],
            "styles": ["projects/admin-app/src/styles.scss"],
            "stylePreprocessorOptions": {
              "includePaths": ["src"]
            },
            "server": "projects/admin-app/src/main.server.ts",
            "outputMode": "server",
            "security": {
              "allowedHosts": [
                "analog-jones-platform--analog-jones-v2.us-central1.hosted.app",
                "*.run.app",
                "localhost"
              ]
            },
            "ssr": {
              "entry": "projects/admin-app/src/server.ts"
            }
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "projects/admin-app/src/environments/environment.ts",
                  "with": "projects/admin-app/src/environments/environment.prod.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "750kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "admin-app:build:production"
            },
            "development": {
              "buildTarget": "admin-app:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "setupFiles": ["projects/admin-app/src/test-setup.ts"]
          }
        },
        "e2e": {
          "builder": "playwright-ng-schematics:playwright",
          "options": {
            "devServerTarget": "admin-app:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "admin-app:serve:production"
            }
          }
        }
      }
    },
    "core": {
      "projectType": "library",
      "root": "projects/core",
      "sourceRoot": "projects/core/src",
      "prefix": "aj",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/core/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/core/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/core/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/core/tsconfig.spec.json",
            "setupFiles": ["projects/core/src/test-setup.ts"]
          }
        }
      }
    }
  }
}
