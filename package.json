{
  "name": "analog-jones-platform",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build $ANGULAR_PROJECT_NAME",
    "build:public": "ng build public-app",
    "build:admin": "ng build admin-app",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:public-app": "node dist/public-app/server/server.mjs",
    "serve:ssr:admin-app": "node dist/admin-app/server/server.mjs",
    "e2e": "ng e2e",
    "emulators:start": "firebase emulators:start",
    "emulators:stop": "lsof -ti:4000,4200,4300,4400,8080,9099,9150,9199 | xargs kill -9 2>/dev/null || true",
    "dev:public": "concurrently --names emulators,app --prefix-colors blue,green \"firebase emulators:start --import=./seed-data\" \"ng serve public-app\"",
    "dev:admin": "concurrently --names emulators,app --prefix-colors blue,green \"firebase emulators:start --import=./seed-data\" \"ng serve admin-app\"",
    "dev:all": "concurrently --names emulators,public,admin --prefix-colors blue,green,magenta \"firebase emulators:start --import=./seed-data\" \"ng serve public-app --port 4200\" \"ng serve admin-app --port 4300\"",
    "deploy:rules": "firebase deploy --only firestore:rules,storage"
  },
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@angular/animations": "^21.2.7",
    "@angular/cdk": "^21.2.4",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.4",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.5",
    "@ngrx/signals": "^21.1.0",
    "express": "^5.1.0",
    "firebase": "^12.11.0",
    "marked": "^18.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.0",
    "@playwright/test": "1.59.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "concurrently": "^9.2.1",
    "firebase-tools": "^15.12.0",
    "jsdom": "^28.0.0",
    "playwright-ng-schematics": "^21.0.9",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
