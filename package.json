{
  "name": "analog-jones-platform",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "pnpm build:core && ng build $ANGULAR_PROJECT_NAME",
    "build:core": "ng build core",
    "build:public": "pnpm build:core && ng build public-app",
    "build:admin": "pnpm build:core && ng build admin-app",
    "watch": "ng build --watch --configuration development",
    "test": "pnpm build:core && concurrently --names public,admin,core \"ng test public-app\" \"ng test admin-app\" \"ng test core\"",
    "test:public": "pnpm build:core && ng test public-app",
    "test:admin": "pnpm build:core && ng test admin-app",
    "test:core": "ng test core",
    "serve:ssr:public-app": "node dist/public-app/server/server.mjs",
    "serve:ssr:admin-app": "node dist/admin-app/server/server.mjs",
    "e2e": "ng e2e",
    "emulators:save": "firebase emulators:export ./seed-data",
    "emulators:start": "firebase emulators:start",
    "emulators:stop": "lsof -ti:4000,4200,4300,4400,8080,9099,9150,9199 | xargs kill -9 2>/dev/null || true",
    "dev:public": "concurrently --names core,emulators,app --prefix-colors yellow,blue,green --kill-others-on-fail \"ng build core --watch\" \"firebase emulators:start --import=./seed-data\" \"wait-on dist/core/fesm2022/aj-core.mjs && ng serve public-app\"",
    "dev:admin": "concurrently --names core,emulators,app --prefix-colors yellow,blue,green --kill-others-on-fail \"ng build core --watch\" \"firebase emulators:start --import=./seed-data\" \"wait-on dist/core/fesm2022/aj-core.mjs && ng serve admin-app\"",
    "dev:all": "concurrently --names core,emulators,public,admin --prefix-colors yellow,blue,green,magenta --kill-others-on-fail \"ng build core --watch\" \"firebase emulators:start --import=./seed-data\" \"wait-on dist/core/fesm2022/aj-core.mjs && ng serve public-app --port 4200\" \"wait-on dist/core/fesm2022/aj-core.mjs && ng serve admin-app --port 4300\"",
    "deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes,storage"
  },
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@angular/animations": "^21.2.11",
    "@angular/cdk": "^21.2.9",
    "@angular/common": "^21.2.11",
    "@angular/compiler": "^21.2.11",
    "@angular/core": "^21.2.11",
    "@angular/forms": "^21.2.11",
    "@angular/material": "^21.2.9",
    "@angular/platform-browser": "^21.2.11",
    "@angular/platform-server": "^21.2.11",
    "@angular/router": "^21.2.11",
    "@angular/ssr": "^21.2.9",
    "@ngrx/signals": "^21.1.0",
    "express": "^5.1.0",
    "firebase": "^12.12.1",
    "marked": "^18.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.11",
    "@playwright/test": "1.59.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/express": "^5.0.1",
    "@types/node": "^20.19.39",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.2.1",
    "firebase-tools": "^15.16.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "playwright-ng-schematics": "^21.0.10",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.9.2",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  }
}
